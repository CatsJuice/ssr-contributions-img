{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn build:playground",
  "outputDirectory": "playground/dist",
  "rewrites": [
    {
      "source": "/_/:username",
      "destination": "/api?__pathname=/_/:username"
    },
    {
      "source": "/svg/:username",
      "destination": "/api?__pathname=/svg/:username"
    },
    {
      "source": "/themes",
      "destination": "/api?__pathname=/themes"
    },
    {
      "source": "/config",
      "destination": "/api?__pathname=/config"
    }
  ]
}
