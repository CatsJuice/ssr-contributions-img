{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd playground && yarn install --frozen-lockfile --production=false && yarn build",
  "outputDirectory": "playground/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "fonts/**"
    }
  },
  "rewrites": [
    {
      "source": "/_/:username",
      "destination": "/api?__pathname=/_/:username"
    },
    {
      "source": "/svg/:username",
      "destination": "/api?__pathname=/svg/:username"
    },
    {
      "source": "/themes",
      "destination": "/api?__pathname=/themes"
    },
    {
      "source": "/config",
      "destination": "/api?__pathname=/config"
    },
    {
      "source": "/contributions/:username",
      "destination": "/api?__pathname=/contributions/:username"
    }
  ]
}
