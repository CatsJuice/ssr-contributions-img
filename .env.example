GITHUB_PAT=${optional, only used for GraphQL fallback and diagnostics}
SERVER_PORT=${number}
PLAYGROUND_ALLOWED_ORIGINS=${optional comma-separated origins, e.g. https://your-domain.com}
PLAYGROUND_DATA_RATE_LIMIT_MAX=${optional integer, default 30}
PLAYGROUND_DATA_RATE_LIMIT_WINDOW_MS=${optional integer milliseconds, default 60000}
PLAYGROUND_DATA_CACHE_TTL_MS=${optional integer milliseconds, default 300000}
